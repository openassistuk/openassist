{
  "name": "@openassist/openassist-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "clean": "node -e \"import fs from \\\"node:fs\\\"; fs.rmSync(\\\"dist\\\", { recursive: true, force: true }); fs.rmSync(\\\"tsconfig.tsbuildinfo\\\", { force: true });\"",
    "dev": "tsx src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@inquirer/prompts": "^7.5.3",
    "@openassist/core-types": "workspace:*",
    "@openassist/observability": "workspace:*",
    "@openassist/core-runtime": "workspace:*",
    "@openassist/config": "workspace:*",
    "commander": "^14.0.1",
    "@openassist/migration-openclaw": "workspace:*",
    "@openassist/storage-sqlite": "workspace:*"
  },
  "bin": {
    "openassist": "dist/index.js"
  }
}
