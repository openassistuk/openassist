{
  "name": "@openassist/openassistd",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "clean": "node -e \"import fs from \\\"node:fs\\\"; fs.rmSync(\\\"dist\\\", { recursive: true, force: true }); fs.rmSync(\\\"tsconfig.tsbuildinfo\\\", { force: true });\"",
    "dev": "tsx src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@openassist/core-runtime": "workspace:*",
    "@openassist/core-types": "workspace:*",
    "@openassist/channels-telegram": "workspace:*",
    "@openassist/channels-discord": "workspace:*",
    "@openassist/providers-azure-foundry": "workspace:*",
    "@openassist/providers-openai-compatible": "workspace:*",
    "@openassist/config": "workspace:*",
    "@openassist/observability": "workspace:*",
    "@openassist/providers-anthropic": "workspace:*",
    "@openassist/providers-codex": "workspace:*",
    "@openassist/storage-sqlite": "workspace:*",
    "@openassist/channels-whatsapp-md": "workspace:*",
    "@openassist/providers-openai": "workspace:*",
    "commander": "^14.0.1"
  },
  "bin": {
    "openassistd": "dist/index.js"
  }
}
