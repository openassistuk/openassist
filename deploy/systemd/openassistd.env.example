# Copy to ~/.config/openassist/openassistd.env and customize values.

# Node environment
NODE_ENV=production

# Provider API keys (example)
# OPENASSIST_PROVIDER_OPENAI_MAIN_API_KEY=replace-me
# OPENASSIST_PROVIDER_ANTHROPIC_MAIN_API_KEY=replace-me

# Optional secret key used for encrypted OAuth token storage.
# If omitted, OpenAssist creates a local key file in runtime data dir.
# OPENASSIST_SECRET_KEY=base64:<32-byte-key-base64>
